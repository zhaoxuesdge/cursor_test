.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mccache/
.pytype/

# =====================
# Jupyter / notebooks checkpoints
# =====================
.ipynb_checkpoints/

# =====================
# Logs (optional but common)
# =====================
*.log